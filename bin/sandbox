#!/usr/bin/env bash
set -euo pipefail

# macOS Sandbox Wrapper Script
# Usage: sandbox [write_path1, write_path2, ...] -- <command> [arguments...]

# Print the static base sandbox profile template to stdout.
print_sandbox_template() {
    cat <<'EOF'
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; macOS Sandbox Configuration Template
;; Reference: sandbox-exec(1)
;;
;; Required profile parameters (provided via `-D key=value`):
;; - HOME - User's home directory: `$(realpath "$HOME")`
;; - TMPDIR - Temp directory: `$(realpath "$TMPDIR")`
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(version 1)
EOF
}

# Configuration paths
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sandbox"
PLUGINS_DIR="${CONFIG_DIR}/plugins"
PROFILES_DIR="${CONFIG_DIR}/profiles"

# List all available profiles with their definition file paths.
# Output: one line per profile: "<name>  <path>"
list_profiles() {
    [[ -d "$PROFILES_DIR" ]] || return 0
    local file name
    for file in "$PROFILES_DIR"/*.sandboxrc; do
        [[ -e "$file" ]] || continue
        name=$(basename "$file")
        name="${name%.sandboxrc}"
        printf '%-16s%s\n' "$name" "$file"
    done | sort
}

# Find the definition file for a profile by name.
# Prints the file path, or nothing if not found.
find_profile() {
    local name="$1"
    [[ -d "$PROFILES_DIR" ]] || return 0
    if [[ -f "$PROFILES_DIR/$name.sandboxrc" ]]; then
        echo "$PROFILES_DIR/$name.sandboxrc"
    fi
}

# List all available plugins with their definition file paths.
# Output: one line per plugin: "<name>  <path>"
list_plugins() {
    [[ -d "$PLUGINS_DIR" ]] || return 0
    local file name
    for file in "$PLUGINS_DIR"/*.sb "$PLUGINS_DIR"/*.sh; do
        [[ -e "$file" ]] || continue
        name=$(basename "$file")
        name="${name%.sb}"
        name="${name%.sh}"
        printf '%-16s%s\n' "$name" "$file"
    done | sort
}

# Find the definition file for a plugin by name.
# Prints the file path, or nothing if not found.
find_plugin() {
    local name="$1"
    [[ -d "$PLUGINS_DIR" ]] || return 0
    if [[ -f "$PLUGINS_DIR/$name.sb" ]]; then
        echo "$PLUGINS_DIR/$name.sb"
    elif [[ -f "$PLUGINS_DIR/$name.sh" ]]; then
        echo "$PLUGINS_DIR/$name.sh"
    fi
}

# Parse an rc/profile file and print one token per line to stdout.
# Blank lines and lines starting with # are ignored.
# ~ is expanded to $HOME. Each line is word-split into tokens.
# $1 = path to the file
parse_rc_file() {
    local file="$1"
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        line="${line//'~'/$HOME}"
        read -ra tokens <<< "$line"
        printf '%s\n' "${tokens[@]+"${tokens[@]}"}"
    done < "$file"
}

usage() {
    cat <<EOF
macOS Sandbox Wrapper
Run commands in a restricted sandbox environment

Usage:
  $(basename "$0") [options]  Print the generated sandbox-exec profile to stdout
  $(basename "$0") [options] -- <command> [arguments...]  Run command inside the sandbox

Options:
  -h, --help                  Show this help message and exit
  --dir <path>                Allow read+write access to a specific directory and its children
  --dir-readonly <path>       Allow read-only access to a specific directory and its children
  --path <path>               Allow read+write access to an exact path (no children)
  --path-readonly <path>      Allow read-only access to an exact path (no children)
  --pattern <regex>           Allow read+write access to paths matching a regex pattern
  --pattern-readonly <regex>  Allow read-only access to paths matching a regex pattern
  --plugin <name>, --plugin=<name>  Enable a named plugin (see below for available plugins)
  --profile <name>, --profile=<name>  Apply a named profile (see below for available profiles)

Available profiles:
$(list_profiles | sed 's/^/  /')

Available plugins:
$(list_plugins | sed 's/^/  /')

Examples:
  # Allow writing to specific directories
  $(basename "$0") --dir ./src --dir ./build -- npm run build

  # Allow writing to paths matching a pattern (e.g. temporary logs)
  $(basename "$0") --pattern "^/var/folders/.*/*.log$" -- touch "$(mktemp -d)"/test.log

  # Preview the generated sandbox profile
  $(basename "$0") --dir ./src

  # Read-only execution (default)
  $(basename "$0") -- ls -la

The default sandbox has no permissions; all access must be explicitly granted.

If a .sandboxrc file exists in the current working directory, it is read as
additional sandbox arguments (appended after any CLI arguments). Blank lines
and lines starting with # are ignored. Each line may contain one or more
flags (e.g. "--dir ~/.config" or "--pattern '^/Volumes/dev/'").

If a .sandboxignore file exists in the current working directory, it is read to
deny read access to additional paths. The file follows gitignore glob syntax:
  - Blank lines and lines starting with # are ignored
  - Patterns without a / match files in any directory (e.g. *.log)
  - Patterns containing a / are anchored to the directory containing .sandboxignore
  - A trailing / restricts the match to directories
  - Prefix ! to negate a rule (re-allow a path blocked by a prior rule)
  - Glob specials: * matches within a path segment, ** matches across segments,
    ? matches any single character, [abc] matches a character class
EOF
}

# ---------------------------------------------------------------------------

# Convert a single gitignore-style glob pattern (already stripped of leading !
# and trailing /) to an extended-regex string anchored to $base_dir.
# $1 = base directory (absolute, no trailing slash)
# $2 = the pattern
# $3 = "dir" if the original pattern had a trailing slash (directory-only)
# Prints the regex, or nothing if the pattern should be skipped.
gitignore_pattern_to_regex() {
    local base="$1"
    local pat="$2"
    local dir_only="${3:-}"

    # Escape the base path for use in a regex
    local escaped_base
    escaped_base="$(printf '%s' "$base" | sed 's/[.[\*^$()+{}|?]/\\&/g')"

    # Determine if the pattern is anchored (contains a / somewhere other than
    # at the very end, which has already been stripped, or starts with /)
    local anchored=false
    if [[ "$pat" == */* ]]; then
        anchored=true
    fi

    # Strip a leading slash (it just means "anchored to base", which we handle)
    pat="${pat#/}"

    # Translate the glob pattern to a regex fragment.
    # Process character by character so we can handle ** correctly.
    local regex_fragment=""
    local i=0
    local len="${#pat}"
    while (( i < len )); do
        local ch="${pat:$i:1}"
        case "$ch" in
            '*')
                if [[ "${pat:$i:2}" == "**" ]]; then
                    # ** matches anything including path separators
                    regex_fragment+=".*"
                    (( i += 2 )) || true
                    # Consume a surrounding / so **/foo and foo/**/bar work
                    # naturally: eat a leading / after ** when present
                    if [[ "${pat:$i:1}" == "/" ]]; then
                        regex_fragment+="(.*/)?"
                        (( i += 1 )) || true
                    fi
                    continue
                else
                    # * matches anything except /
                    regex_fragment+="[^/]*"
                fi
                ;;
            '?')
                regex_fragment+="[^/]"
                ;;
            '.')
                regex_fragment+="\."
                ;;
            '[')
                # Pass character classes through verbatim until the closing ]
                local class="["
                (( i += 1 )) || true
                while (( i < len )) && [[ "${pat:$i:1}" != "]" ]]; do
                    class+="${pat:$i:1}"
                    (( i += 1 )) || true
                done
                class+="]"
                regex_fragment+="$class"
                ;;
            '+' | '^' | '$' | '{' | '}' | '(' | ')' | '|' | '\\')
                regex_fragment+="\\$ch"
                ;;
            *)
                regex_fragment+="$ch"
                ;;
        esac
        (( i += 1 )) || true
    done

    local regex
    if $anchored; then
        # Anchored: pattern must match relative to $base
        if [[ -n "$dir_only" ]]; then
            # Must match a directory: path is either exactly this dir or a subpath
            regex="^${escaped_base}/${regex_fragment}(/.*)?$"
        else
            regex="^${escaped_base}/${regex_fragment}(/.*)?$"
        fi
    else
        # Unanchored: pattern matches a filename in any directory under $base,
        # or $base itself
        if [[ -n "$dir_only" ]]; then
            regex="^${escaped_base}(/.*)/${regex_fragment}(/.*)?$"
        else
            regex="^${escaped_base}(/.*)?/${regex_fragment}(/.*)?$"
        fi
    fi

    printf '%s' "$regex"
}

# ---------------------------------------------------------------------------
# Sandbox profile expression factory functions.
# Each function prints a sandbox scheme expression to stdout.
# Compose them with $(...) substitution.
# ---------------------------------------------------------------------------

# Location expressions
literal_expression() { printf '(literal %s)' "$1"; }
subpath_expression() { printf '(subpath %s)' "$1"; }
regex_expression()   { printf '(regex #"%s")' "$1"; }

# Quoted helpers for plain absolute paths (the common case for --dir / --path)
literal_path_expression()  { literal_expression "\"$1\""; }
subpath_path_expression()  { subpath_expression "\"$1\""; }

# Permission rule constructors
allow_read_rule()       { printf '(allow file-read* %s)'            "$1"; }
allow_read_write_rule() { printf '(allow file-read* file-write* %s)' "$1"; }
deny_read_rule()        { printf '(deny file-read* %s)'             "$1"; }

# Parse a .sandboxignore file and emit sandbox profile rule strings, one per line.
# Deny rules are emitted first, then allow (negation) rules so that negations win.
# $1 = path to the .sandboxignore file
# $2 = base directory (absolute, no trailing slash)
emit_sandboxignore_rules() {
    local file="$1"
    local base="$2"

    local deny_rules=()
    local allow_rules=()

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue

        local negated=false
        if [[ "$line" == \!* ]]; then
            negated=true
            line="${line:1}"
        fi

        # Strip trailing /  (record whether it was present)
        local dir_only=""
        if [[ "$line" == */ ]]; then
            dir_only="dir"
            line="${line%/}"
        fi

        # Skip empty pattern after stripping
        [[ -z "$line" ]] && continue

        local regex
        regex="$(gitignore_pattern_to_regex "$base" "$line" "$dir_only")"
        [[ -z "$regex" ]] && continue

        if $negated; then
            allow_rules+=("$(allow_read_rule "$(regex_expression "$regex")")")
        else
            deny_rules+=("$(deny_read_rule "$(regex_expression "$regex")")")
        fi
    done < "$file"

    for rule in "${deny_rules[@]+"${deny_rules[@]}"}"; do
        echo "$rule"
    done
    for rule in "${allow_rules[@]+"${allow_rules[@]}"}"; do
        echo "$rule"
    done
}

# Resolve a path argument to an absolute path and print it.
# $1 = the raw path value
resolve_dir() {
    local arg="$1"
    if [[ -d "$arg" ]]; then
        cd "$arg" && pwd
    elif [[ -f "$arg" ]]; then
        echo "$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"
    elif [[ "$arg" == /* ]]; then
        echo "$arg"
    else
        echo "$(pwd)/$arg"
    fi
}

# Collect CLI option tokens (everything before --) and COMMAND_ARGS (everything after).
# Also handle --help early since it exits immediately.
COMMAND_MODE=false
COMMAND_ARGS=()
cli_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --)
            shift
            COMMAND_MODE=true
            COMMAND_ARGS=("$@")
            break
            ;;
        *)
            cli_args+=("$1")
            shift
            ;;
    esac
done

# Collect .sandboxrc tokens, if the file exists.
rc_args=()
SANDBOXRC_FILE="$(pwd)/.sandboxrc"
if [[ -f "$SANDBOXRC_FILE" ]]; then
    while IFS= read -r token; do rc_args+=("$token"); done < <(parse_rc_file "$SANDBOXRC_FILE")
fi

# Parse all option tokens - CLI args first, then rc args - and accumulate
# sandbox profile rule blocks into profile_sections.
profile_sections=()
_section_depth=0

# Append a commented section (and optional rule content) to profile_sections,
# indented according to the current _section_depth.
add_section() {
    local comment="$1"
    local rule="${2-}"
    local indent
    indent=$(printf '%*s' "$_section_depth" '' | tr ' ' $'\t')

    local entry="${indent};; ${comment}"
    if [[ -n "$rule" ]]; then
        local indented_rule
        indented_rule=$(printf '%s\n' "$rule" | sed "s/^/${indent}/")
        entry+=$'\n'"${indented_rule}"
    fi
    profile_sections+=("$entry")
}

# Process an argument list and append sandbox rules to profile_sections.
# Called recursively for --profile expansion (depth-first).
process_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --dir requires a path." >&2
                    exit 1
                fi
                add_section "--dir $2" "$(allow_read_write_rule "$(subpath_path_expression "$(resolve_dir "$2")")")" 
                shift 2
                ;;
            --dir-readonly)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --dir-readonly requires a path." >&2
                    exit 1
                fi
                add_section "--dir-readonly $2" "$(allow_read_rule "$(subpath_path_expression "$(resolve_dir "$2")")")" 
                shift 2
                ;;
            --path)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --path requires a path." >&2
                    exit 1
                fi
                add_section "--path $2" "$(allow_read_write_rule "$(literal_path_expression "$(resolve_dir "$2")")")" 
                shift 2
                ;;
            --path-readonly)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --path-readonly requires a path." >&2
                    exit 1
                fi
                add_section "--path-readonly $2" "$(allow_read_rule "$(literal_path_expression "$(resolve_dir "$2")")")" 
                shift 2
                ;;
            --pattern)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --pattern requires a regex." >&2
                    exit 1
                fi
                add_section "--pattern $2" "$(allow_read_write_rule "$(regex_expression "$2")")"
                shift 2
                ;;
            --pattern-readonly)
                if [[ -z "${2-}" ]]; then
                    echo "Error: --pattern-readonly requires a regex." >&2
                    exit 1
                fi
                add_section "--pattern-readonly $2" "$(allow_read_rule "$(regex_expression "$2")")"
                shift 2
                ;;
            --plugin|--plugin=*)
                if [[ "$1" == --plugin=* ]]; then
                    plugin_name="${1#--plugin=}"
                    shift
                else
                    if [[ $# -lt 2 ]]; then
                        echo "Error: --plugin requires a plugin name." >&2
                        usage >&2
                        exit 1
                    fi
                    plugin_name="$2"
                    shift 2
                fi
                plugin_file=$(find_plugin "$plugin_name")
                if [[ -z "$plugin_file" ]]; then
                    echo "Error: Unknown plugin '$plugin_name'." >&2
                    usage >&2
                    exit 1
                fi
                if [[ "$plugin_file" == *.sh ]]; then
                    plugin_rules=$(bash "$plugin_file")
                else
                    plugin_rules=$(cat "$plugin_file")
                fi
                add_section "--plugin $plugin_name" "$plugin_rules"
                ;;
            --profile|--profile=*)
                if [[ "$1" == --profile=* ]]; then
                    profile_name="${1#--profile=}"
                    shift
                else
                    if [[ $# -lt 2 ]]; then
                        echo "Error: --profile requires a name." >&2
                        usage >&2
                        exit 1
                    fi
                    profile_name="$2"
                    shift 2
                fi
                profile_file=$(find_profile "$profile_name")
                if [[ -z "$profile_file" ]]; then
                    echo "Error: Unknown profile '$profile_name'." >&2
                    usage >&2
                    exit 1
                fi
                add_section "--profile $profile_name"
                (( _section_depth++ ))
                local profile_tokens=()
                while IFS= read -r token; do profile_tokens+=("$token"); done < <(parse_rc_file "$profile_file")
                process_args "${profile_tokens[@]+"${profile_tokens[@]}"}"
                (( _section_depth-- ))
                ;;
            *)
                echo "Error: Unknown argument '$1'." >&2
                usage >&2
                exit 1
                ;;
        esac
    done
}

add_section "Deny default rules" "(deny default)"
process_args "${cli_args[@]+${cli_args[@]}}" "${rc_args[@]+${rc_args[@]}}"

# Validate arguments
if [[ "$COMMAND_MODE" == true && ${#COMMAND_ARGS[@]} -eq 0 ]]; then
    echo "Error: No command provided after '--'." >&2
    usage >&2
    exit 1
fi

# Add rules from .sandboxignore, if present
SANDBOXIGNORE_FILE="$(pwd)/.sandboxignore"
if [[ -f "$SANDBOXIGNORE_FILE" ]]; then
    while IFS= read -r rule; do
        profile_sections+=("$rule")
    done < <(emit_sandboxignore_rules "$SANDBOXIGNORE_FILE" "$(pwd)")
fi

# Create the sandbox profile (template + dynamic rules)
profile_source=$(
    print_sandbox_template
    echo ""
    for section in "${profile_sections[@]+"${profile_sections[@]}"}"; do
        echo "$section"
        echo ""
    done
)

# If no command was specified, write the profile to stdout and exit
if [[ "$COMMAND_MODE" == false ]]; then
    echo "$profile_source"
    exit 0
fi

# Execute the command in the sandbox environment
exec sandbox-exec -p "$profile_source" -D HOME="$(realpath "$HOME")" -D TMPDIR="$(realpath "$TMPDIR")" "${COMMAND_ARGS[@]}"
