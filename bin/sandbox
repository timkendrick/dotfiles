#!/usr/bin/env bash
set -euo pipefail

# macOS Sandbox Wrapper Script
# Usage: sandbox [write_path1, write_path2, ...] -- <command> [arguments...]

# Script setup
SCRIPT_DIR="$(dirname "$0")"
CONFIG_TEMPLATE="$SCRIPT_DIR/sandbox.sb"

if [[ ! -f "$CONFIG_TEMPLATE" ]]; then
    echo "Error: Sandbox template file not found at $CONFIG_TEMPLATE" >&2
    exit 1
fi

usage() {
    cat <<EOF
macOS Sandbox Wrapper
Run commands in a restricted sandbox environment with read-only filesystem access

Usage:
  $(basename "$0") [options] -- <command> [arguments...]

Options:
  -h, --help                  Show this help message and exit
  --dir <path>                Allow read+write access to a specific directory and its children
  --dir-readonly <path>       Allow read-only access to a specific directory and its children
  --path <path>               Allow read+write access to an exact path (no children)
  --path-readonly <path>      Allow read-only access to an exact path (no children)
  --pattern <regex>           Allow read+write access to paths matching a regex pattern
  --pattern-readonly <regex>  Allow read-only access to paths matching a regex pattern

Tool-specific convenience flags:
  --bash                Allow read-only access to ~/.bashrc, ~/.profile and ~/.bash_profile
  --claude              Allow read+write access to ~/.claude.json and ~/.claude/
  --docker              Allow read access to ~/.docker and write access to ~/.docker/buildx
  --git                 Allow read access to git config files in the home directory
  --jj                  Allow read access to jj config files in the home directory
  --keychain            Allow read access to the macOS keychain (via the security CLI)
  --mise                Allow read access to all mise-managed tool installs
  --node                Allow write access to ~/.cache/node/corepack
  --npm                 Allow write access to ~/.npm
  --pi                  Allow write access to ~/.pi
  --plannotator         Allow write access to ~/.plannotator
  --pnpm                Allow write access to ~/Library/pnpm
  --vim                 Allow read access to ~/.vimrc and ~/.vim
  --zsh                 Allow read-only access to ~/.zshenv, ~/.zshrc, and ~/.zprofile
  --git-repo            Allow write access to the git repository root (detected via git rev-parse)
  --jj-repo             Allow write access to the jj workspace root (and linked repo, if any)

Examples:
  # Allow writing to specific directories
  $(basename "$0") --dir ./src --dir ./build -- npm run build

  # Allow writing to paths matching a pattern (e.g. temporary logs)
  $(basename "$0") --pattern "^/var/folders/.*/*.log$" -- touch "$(mktemp -d)"/test.log

  # Read-only execution (default)
  $(basename "$0") -- ls -la

Files within the user's home directory are blocked by default.

If a .sandboxrc file exists in the current working directory, it is read as
additional sandbox arguments (appended after any CLI arguments). Blank lines
and lines starting with # are ignored. Each line may contain one or more
flags (e.g. "--dir ~/.config" or "--pattern '^/Volumes/dev/'").

If a .sandboxignore file exists in the current working directory, it is read to
deny read access to additional paths. The file follows gitignore glob syntax:
  - Blank lines and lines starting with # are ignored
  - Patterns without a / match files in any directory (e.g. *.log)
  - Patterns containing a / are anchored to the directory containing .sandboxignore
  - A trailing / restricts the match to directories
  - Prefix ! to negate a rule (re-allow a path blocked by a prior rule)
  - Glob specials: * matches within a path segment, ** matches across segments,
    ? matches any single character, [abc] matches a character class
EOF
}

# Convert a single gitignore-style glob pattern (already stripped of leading !
# and trailing /) to an extended-regex string anchored to $base_dir.
# $1 = base directory (absolute, no trailing slash)
# $2 = the pattern
# $3 = "dir" if the original pattern had a trailing slash (directory-only)
# Prints the regex, or nothing if the pattern should be skipped.
gitignore_pattern_to_regex() {
    local base="$1"
    local pat="$2"
    local dir_only="${3:-}"

    # Escape the base path for use in a regex
    local escaped_base
    escaped_base="$(printf '%s' "$base" | sed 's/[.[\*^$()+{}|?]/\\&/g')"

    # Determine if the pattern is anchored (contains a / somewhere other than
    # at the very end, which has already been stripped, or starts with /)
    local anchored=false
    if [[ "$pat" == */* ]]; then
        anchored=true
    fi

    # Strip a leading slash (it just means "anchored to base", which we handle)
    pat="${pat#/}"

    # Translate the glob pattern to a regex fragment.
    # Process character by character so we can handle ** correctly.
    local regex_fragment=""
    local i=0
    local len="${#pat}"
    while (( i < len )); do
        local ch="${pat:$i:1}"
        case "$ch" in
            '*')
                if [[ "${pat:$i:2}" == "**" ]]; then
                    # ** matches anything including path separators
                    regex_fragment+=".*"
                    (( i += 2 )) || true
                    # Consume a surrounding / so **/foo and foo/**/bar work
                    # naturally: eat a leading / after ** when present
                    if [[ "${pat:$i:1}" == "/" ]]; then
                        regex_fragment+="(.*/)?"
                        (( i += 1 )) || true
                    fi
                    continue
                else
                    # * matches anything except /
                    regex_fragment+="[^/]*"
                fi
                ;;
            '?')
                regex_fragment+="[^/]"
                ;;
            '.')
                regex_fragment+="\."
                ;;
            '[')
                # Pass character classes through verbatim until the closing ]
                local class="["
                (( i += 1 )) || true
                while (( i < len )) && [[ "${pat:$i:1}" != "]" ]]; do
                    class+="${pat:$i:1}"
                    (( i += 1 )) || true
                done
                class+="]"
                regex_fragment+="$class"
                ;;
            '+' | '^' | '$' | '{' | '}' | '(' | ')' | '|' | '\\')
                regex_fragment+="\\$ch"
                ;;
            *)
                regex_fragment+="$ch"
                ;;
        esac
        (( i += 1 )) || true
    done

    local regex
    if $anchored; then
        # Anchored: pattern must match relative to $base
        if [[ -n "$dir_only" ]]; then
            # Must match a directory: path is either exactly this dir or a subpath
            regex="^${escaped_base}/${regex_fragment}(/.*)?$"
        else
            regex="^${escaped_base}/${regex_fragment}(/.*)?$"
        fi
    else
        # Unanchored: pattern matches a filename in any directory under $base,
        # or $base itself
        if [[ -n "$dir_only" ]]; then
            regex="^${escaped_base}(/.*)/${regex_fragment}(/.*)?$"
        else
            regex="^${escaped_base}(/.*)?/${regex_fragment}(/.*)?$"
        fi
    fi

    printf '%s' "$regex"
}

# Parse a .sandboxignore file and emit sandbox profile lines.
# $1 = path to the .sandboxignore file
# $2 = base directory (absolute, no trailing slash)
emit_sandboxignore_rules() {
    local file="$1"
    local base="$2"

    local deny_rules=()
    local allow_rules=()

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue

        local negated=false
        if [[ "$line" == \!* ]]; then
            negated=true
            line="${line:1}"
        fi

        # Strip trailing /  (record whether it was present)
        local dir_only=""
        if [[ "$line" == */ ]]; then
            dir_only="dir"
            line="${line%/}"
        fi

        # Skip empty pattern after stripping
        [[ -z "$line" ]] && continue

        local regex
        regex="$(gitignore_pattern_to_regex "$base" "$line" "$dir_only")"
        [[ -z "$regex" ]] && continue

        if $negated; then
            allow_rules+=("(allow file-read* (regex #\"${regex}\"))")
        else
            deny_rules+=("(deny file-read* (regex #\"${regex}\"))")
        fi
    done < "$file"

    # Emit deny rules first, then allow (negation) rules so that negations win
    for rule in "${deny_rules[@]+"${deny_rules[@]}"}"; do
        echo "$rule"
    done
    for rule in "${allow_rules[@]+"${allow_rules[@]}"}"; do
        echo "$rule"
    done
}

# Resolve a path argument to an absolute path and print it.
# $1 = the raw path value
resolve_dir() {
    local arg="$1"
    if [[ -d "$arg" ]]; then
        cd "$arg" && pwd
    elif [[ -f "$arg" ]]; then
        echo "$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"
    elif [[ "$arg" == /* ]]; then
        echo "$arg"
    else
        echo "$(pwd)/$arg"
    fi
}

# Collect CLI option tokens (everything before --) and COMMAND_ARGS (everything after).
# Also handle --help early since it exits immediately.
COMMAND_ARGS=()
SEPARATOR_FOUND=false
cli_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --)
            SEPARATOR_FOUND=true
            shift
            COMMAND_ARGS=("$@")
            break
            ;;
        *)
            cli_args+=("$1")
            shift
            ;;
    esac
done

# Collect .sandboxrc tokens, if the file exists.
rc_args=()
SANDBOXRC_FILE="$(pwd)/.sandboxrc"
if [[ -f "$SANDBOXRC_FILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue
        # Expand ~ to $HOME, then word-split the line into tokens
        line="${line//'~'/$HOME}"
        read -ra tokens <<< "$line"
        rc_args+=("${tokens[@]}")
    done < "$SANDBOXRC_FILE"
fi

# Parse all option tokens — CLI args first, then rc args — through one shared loop.
PATHS=()
READONLY_PATHS=()
LITERAL_PATHS=()
READONLY_LITERAL_PATHS=()
PATTERNS=()
READONLY_PATTERNS=()
set -- "${cli_args[@]+${cli_args[@]}}" "${rc_args[@]+${rc_args[@]}}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir)
            if [[ -z "${2-}" ]]; then
                echo "Error: --dir requires a path." >&2
                exit 1
            fi
            PATHS+=("$(resolve_dir "$2")")
            shift 2
            ;;
        --dir-readonly)
            if [[ -z "${2-}" ]]; then
                echo "Error: --dir-readonly requires a path." >&2
                exit 1
            fi
            READONLY_PATHS+=("$(resolve_dir "$2")")
            shift 2
            ;;
        --path)
            if [[ -z "${2-}" ]]; then
                echo "Error: --path requires a path." >&2
                exit 1
            fi
            LITERAL_PATHS+=("$(resolve_dir "$2")")
            shift 2
            ;;
        --path-readonly)
            if [[ -z "${2-}" ]]; then
                echo "Error: --path-readonly requires a path." >&2
                exit 1
            fi
            READONLY_LITERAL_PATHS+=("$(resolve_dir "$2")")
            shift 2
            ;;
        --pattern)
            if [[ -z "${2-}" ]]; then
                echo "Error: --pattern requires a regex." >&2
                exit 1
            fi
            PATTERNS+=("$2")
            shift 2
            ;;
        --pattern-readonly)
            if [[ -z "${2-}" ]]; then
                echo "Error: --pattern-readonly requires a regex." >&2
                exit 1
            fi
            READONLY_PATTERNS+=("$2")
            shift 2
            ;;
        --bash)
            READONLY_LITERAL_PATHS+=("$HOME/.bashrc")
            READONLY_LITERAL_PATHS+=("$HOME/.profile")
            READONLY_LITERAL_PATHS+=("$HOME/.bash_profile")
            shift
            ;;
        --claude)
            PATHS+=("$HOME/.claude")
            LITERAL_PATHS+=("$HOME/.claude.json")
            shift
            ;;
        --git)
            READONLY_PATHS+=("$HOME/.config/git")
            READONLY_LITERAL_PATHS+=("$HOME/.gitconfig")
            shift
            ;;
        --jj)
            READONLY_LITERAL_PATHS+=("$HOME/.config/jj")
            shift
            ;;
        --keychain)
            READONLY_PATHS+=("$HOME/Library/Keychains")
            shift
            ;;
        --git-repo)
            if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
                PATHS+=("$(realpath "$git_root")")
            fi
            shift
            ;;
        --jj-repo)
            if jj_root=$(jj workspace root 2>/dev/null); then
                PATHS+=("$jj_root")
                if [[ -f "$jj_root/.jj/repo" ]]; then
                    linked_repo=$(cat "$jj_root/.jj/repo")
                    PATHS+=("$(realpath "$(dirname "$(dirname "$linked_repo")")")") 
                fi
            fi
            shift
            ;;
        --pi)
            PATHS+=("$HOME/.pi")
            shift
            ;;
        --plannotator)
            PATHS+=("$HOME/.plannotator")
            shift
            ;;
        --node)
            PATHS+=("$HOME/.cache/node/corepack")
            shift
            ;;
        --npm)
            PATHS+=("$HOME/.npm")
            READONLY_LITERAL_PATHS+=("$HOME/.npmrc")
            shift
            ;;
        --pnpm)
            PATHS+=("$HOME/Library/pnpm")
            READONLY_PATHS+=("$HOME/Library/Preferences/pnpm")
            READONLY_LITERAL_PATHS+=("$HOME/.npmrc")
            shift
            ;;
        --vim)
            READONLY_LITERAL_PATHS+=("$HOME/.vimrc")
            READONLY_PATHS+=("$HOME/.vim")
            shift
            ;;
        --zsh)
            READONLY_LITERAL_PATHS+=("$HOME/.zshenv")
            READONLY_LITERAL_PATHS+=("$HOME/.zshrc")
            READONLY_LITERAL_PATHS+=("$HOME/.zprofile")
            shift
            ;;
        --docker)
            READONLY_PATHS+=("$HOME/.docker")
            PATHS+=("$HOME/.docker/buildx")
            shift
            ;;
        --mise)
            # Allow read-only access to all mise-installed tools
            mise_data_dir="${MISE_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/mise}"
            READONLY_PATHS+=("$mise_data_dir")
            shift
            ;;
        *)
            echo "Error: Unknown argument '$1'." >&2
            usage >&2
            exit 1
            ;;
    esac
done

# Validate arguments
if [[ "$SEPARATOR_FOUND" == "false" ]]; then
    echo "Error: Missing '--' separator." >&2
    usage >&2
    exit 1
fi
if [[ ${#COMMAND_ARGS[@]} -eq 0 ]]; then
    echo "Error: No command provided after '--'." >&2
    usage >&2
    exit 1
fi

# Load .sandboxignore from the current working directory, if present
SANDBOXIGNORE_FILE="$(pwd)/.sandboxignore"

# Create the sandbox profile (template + appended rules)
profile_source=$(
    cat "$CONFIG_TEMPLATE"
    echo ""
    echo ";; Allow read access to PATH directories for locating executables"
    IFS=: read -ra path_dirs <<< "$PATH"
    for path_dir in "${path_dirs[@]}"; do
        # Resolve relative entries against CWD
        [[ "$path_dir" != /* ]] && path_dir="$(pwd)/$path_dir"
        echo "(allow file-read* (subpath \"$path_dir\"))"
    done
    if [[ -f "$SANDBOXIGNORE_FILE" ]]; then
        echo ""
        echo ";; --- IGNORE RULES ---"
        emit_sandboxignore_rules "$SANDBOXIGNORE_FILE" "$(pwd)"
        echo ";; --- END OF IGNORE RULES ---"
        echo ""
    fi
    echo ""
    echo ";; --- DYNAMIC RULES ---"
    if [[ ${#READONLY_LITERAL_PATHS[@]} -gt 0 ]]; then
        for path in "${READONLY_LITERAL_PATHS[@]}"; do
            echo "(allow file-read* (literal \"$path\"))"
        done
    fi
    if [[ ${#READONLY_PATHS[@]} -gt 0 ]]; then
        for dir in "${READONLY_PATHS[@]}"; do
            echo "(allow file-read* (subpath \"$dir\"))"
        done
    fi
    if [[ ${#READONLY_PATTERNS[@]} -gt 0 ]]; then
        for pattern in "${READONLY_PATTERNS[@]}"; do
            echo "(allow file-read* (regex #\"$pattern\"))"
        done
    fi
    if [[ ${#LITERAL_PATHS[@]} -gt 0 ]]; then
        for path in "${LITERAL_PATHS[@]}"; do
            echo "(allow file-read* file-write* (literal \"$path\"))"
        done
    fi
    if [[ ${#PATHS[@]} -gt 0 ]]; then
        for dir in "${PATHS[@]}"; do
            echo "(allow file-read* file-write* (subpath \"$dir\"))"
        done
    fi
    if [[ ${#PATTERNS[@]} -gt 0 ]]; then
        for pattern in "${PATTERNS[@]}"; do
            echo "(allow file-read* file-write* (regex #\"$pattern\"))"
        done
    fi
    echo ";; --- END OF DYNAMIC RULES ---"
)

# If the SANDBOX_DEBUG environment variable is set, print the generated profile for debugging
if [[ -n "${SANDBOX_DEBUG-}" ]]; then
    echo "$profile_source" >&2
fi

# Execute the command in the sandbox environment
exec sandbox-exec -p "$profile_source" -D HOME="$(realpath "$HOME")" -D TMPDIR="$(realpath "$TMPDIR")" "${COMMAND_ARGS[@]}"
